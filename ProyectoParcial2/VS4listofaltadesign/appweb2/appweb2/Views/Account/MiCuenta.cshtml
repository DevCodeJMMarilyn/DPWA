@model appweb2.Models.GestionCuentaViewModel

@{
    ViewData["Title"] = "Mi cuenta";
}

<div class="arcade-page-header mb-4">
    <div>
        <h2 class="arcade-page-title"><i class="fas fa-user-gear me-2"></i>Mi cuenta</h2>
        <p class="arcade-page-sub">Actualiza tu nombre y cambia tu contraseña si lo deseas.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="VideoJuegos" asp-action="Index" class="btn-arcade-sm btn-arcade-outline">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

@if (TempData["CuentaMensaje"] is string mensaje && !string.IsNullOrWhiteSpace(mensaje))
{
    <div class="arcade-alert-success mb-3"><i class="fas fa-check-circle me-2"></i>@mensaje</div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="arcade-panel h-100">
            <div class="arcade-panel-header">
                <i class="fas fa-id-badge me-2"></i>Informacion actual
            </div>
            <div class="arcade-panel-body">
                <div class="mb-3">
                    <label class="arcade-label">Correo</label>
                    <div class="carrito-metodo-pago">
                        <i class="fas fa-envelope"></i>
                        <span>@Model.Email</span>
                    </div>
                </div>
                <p class="text-muted mb-0">Tu correo se mantiene como identificador de acceso. Desde aqui puedes actualizar tu nombre y tu contraseña.</p>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="arcade-panel">
            <div class="arcade-panel-header">
                <i class="fas fa-pen-to-square me-2"></i>Editar datos
            </div>
            <div class="arcade-panel-body">
                <form asp-action="MiCuenta" method="post">
                    <div asp-validation-summary="ModelOnly" class="arcade-alert-error mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="arcade-label"></label>
                        <input asp-for="Nombre" class="form-control arcade-input" placeholder="Tu nombre" />
                        <span asp-validation-for="Nombre" class="arcade-field-error"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="arcade-label"></label>
                        <input asp-for="Email" class="form-control arcade-input" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="arcade-label"></label>
                        <input asp-for="CurrentPassword" type="password" class="form-control arcade-input" placeholder="Solo si deseas cambiarla" />
                        <span asp-validation-for="CurrentPassword" class="arcade-field-error"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="arcade-label"></label>
                            <input asp-for="NewPassword" type="password" class="form-control arcade-input" placeholder="Minimo 6 caracteres" />
                            <span asp-validation-for="NewPassword" class="arcade-field-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmNewPassword" class="arcade-label"></label>
                            <input asp-for="ConfirmNewPassword" type="password" class="form-control arcade-input" placeholder="Repite la nueva contrasena" />
                            <span asp-validation-for="ConfirmNewPassword" class="arcade-field-error"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-3 flex-wrap mt-4">
                        <button type="submit" class="btn-arcade-primary">
                            <i class="fas fa-save me-2"></i>Guardar cambios
                        </button>
                        <a asp-action="MisCompras" class="btn-arcade-sm btn-arcade-outline">
                            <i class="fas fa-bag-shopping me-1"></i>Mis compras
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
