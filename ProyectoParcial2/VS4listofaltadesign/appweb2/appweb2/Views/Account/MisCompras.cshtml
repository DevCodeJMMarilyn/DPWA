@model IEnumerable<appweb2.Models.CompraUsuarioViewModel>

@{
    ViewData["Title"] = "Mis compras";
}

<div class="arcade-page-header mb-4">
    <div>
        <h2 class="arcade-page-title"><i class="fas fa-bag-shopping me-2"></i>Mis compras</h2>
        <p class="arcade-page-sub">Historial de todas tus compras realizadas.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Account"
           asp-action="MisComprasPdf"
           asp-route-desde="@(ViewBag.Desde != null ? ((DateTime)ViewBag.Desde).ToString("yyyy-MM-dd") : null)"
           asp-route-hasta="@(ViewBag.Hasta != null ? ((DateTime)ViewBag.Hasta).ToString("yyyy-MM-dd") : null)"
           asp-route-juego="@ViewBag.Juego"
           class="btn-arcade-sm btn-arcade-outline">
            <i class="fas fa-file-pdf me-1"></i>Reporte compras
        </a>
        <a asp-controller="VideoJuegos" asp-action="Carrito" class="btn-arcade-sm btn-arcade-outline">
            <i class="fas fa-cart-shopping me-1"></i>Ver carrito
        </a>
        <a asp-controller="VideoJuegos" asp-action="Index" class="btn-arcade-sm btn-arcade-gold">
            <i class="fas fa-gamepad me-1"></i>Seguir comprando
        </a>
    </div>
</div>

<div class="arcade-panel mb-4">
    <div class="arcade-panel-header">
        <i class="fas fa-filter me-2"></i>Filtrar compras
    </div>
    <div class="arcade-panel-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="arcade-label">Desde</label>
                <input type="date" name="desde" class="form-control arcade-input" value="@(ViewBag.Desde != null ? ((DateTime)ViewBag.Desde).ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-3">
                <label class="arcade-label">Hasta</label>
                <input type="date" name="hasta" class="form-control arcade-input" value="@(ViewBag.Hasta != null ? ((DateTime)ViewBag.Hasta).ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-4">
                <label class="arcade-label">Videojuego</label>
                <input type="text" name="juego" class="form-control arcade-input" value="@ViewBag.Juego" placeholder="Nombre del videojuego" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn-arcade-primary">
                    <i class="fas fa-search me-1"></i>Filtrar
                </button>
                <a asp-action="MisCompras" class="btn-arcade-sm btn-arcade-outline">
                    Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="arcade-panel">
        <div class="arcade-panel-header">
            <i class="fas fa-receipt me-2"></i>Historial de compras
        </div>
        <div class="arcade-panel-body p-0">
            <div class="table-responsive">
                <table class="arcade-table">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Juego</th>
                            <th>Cantidad</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Codigo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Numero</td>
                                <td><span class="fw-bold">@item.Juego</span></td>
                                <td>@item.Cantidad</td>
                                <td><span class="price" style="font-size:1rem;">$@item.Total</span></td>
                                <td><span class="arcade-badge-success">@item.Estado</span></td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><code class="arcade-code">@item.CodigoTransaccion</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="arcade-empty-state">
        <i class="fas fa-bag-shopping"></i>
        <h3>No se encontraron compras</h3>
        <p>Prueba con otro rango de fechas o con un nombre de videojuego distinto.</p>
        <a asp-controller="VideoJuegos" asp-action="Index" class="btn-arcade-primary mt-2">
            <i class="fas fa-gamepad me-2"></i>Ir al catalogo
        </a>
    </div>
}
