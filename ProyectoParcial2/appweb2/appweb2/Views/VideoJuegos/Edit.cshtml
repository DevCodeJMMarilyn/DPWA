@model appweb2.Models.VideoJuego

<div class="arcade-page-header mb-4">
    <div>
        <h2 class="arcade-page-title"><i class="fas fa-edit me-2"></i>Editar videojuego</h2>
        <p class="arcade-page-sub">Actualiza precio, categoría, promoción y contenido visible del juego.</p>
    </div>
    <a asp-action="GestionCategorias" class="btn-arcade-sm btn-arcade-outline">
        <i class="fas fa-tags me-1"></i>Gestionar categorías
    </a>
</div>

<div class="arcade-panel">
    <div class="arcade-panel-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="arcade-alert-error mb-3"></div>

            <div class="row g-4">
                <!-- Columna principal de campos -->
                <div class="col-lg-8">
                    <div class="row g-4">
                        <div class="col-md-8">
                            <label asp-for="Titulo" class="edit-label">Título</label>
                            <input asp-for="Titulo" class="form-control edit-input" placeholder="Nombre del juego" />
                            <span asp-validation-for="Titulo" class="arcade-field-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoriaId" class="edit-label">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select edit-input" asp-items="ViewBag.Categorias"></select>
                            <span asp-validation-for="CategoriaId" class="arcade-field-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Precio" class="edit-label">Precio normal ($)</label>
                            <input asp-for="Precio" type="number" step="0.01" min="0.01" class="form-control edit-input" />
                            <span asp-validation-for="Precio" class="arcade-field-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PrecioPromocion" class="edit-label">Precio promoción ($)</label>
                            <input asp-for="PrecioPromocion" type="number" step="0.01" min="0" class="form-control edit-input" />
                            <span asp-validation-for="PrecioPromocion" class="arcade-field-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EdadMinima" class="edit-label">Edad mínima</label>
                            <input asp-for="EdadMinima" type="number" min="0" max="21" class="form-control edit-input" />
                            <span asp-validation-for="EdadMinima" class="arcade-field-error"></span>
                        </div>
                        <div class="col-12">
                            <div class="edit-switch-wrapper">
                                <input asp-for="EnPromocion" class="edit-switch-input" type="checkbox" role="switch" />
                                <label asp-for="EnPromocion" class="edit-switch-label">Mantener activo en promoción</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Descripcion" class="edit-label">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control edit-input" rows="5" placeholder="Descripción del juego..."></textarea>
                            <span asp-validation-for="Descripcion" class="arcade-field-error"></span>
                        </div>
                        <div class="col-12">
                            <label class="edit-label">Reemplazar imagen</label>
                            <input type="file" name="archivoImagen" class="form-control edit-input" accept="image/*" />
                        </div>
                    </div>
                </div>

                <!-- Columna imagen actual -->
                <div class="col-lg-4">
                    <div class="edit-img-panel h-100">
                        <div class="edit-img-panel-header">
                            <i class="fas fa-image me-1"></i> Imagen actual
                        </div>
                        <div class="edit-img-panel-body">
                            @if (!string.IsNullOrWhiteSpace(Model.Imagen))
                            {
                                <img src="@Model.Imagen" class="img-fluid rounded-3 edit-preview-img" alt="Portada de @Model.Titulo" />
                            }
                            else
                            {
                                <div class="edit-no-img">
                                    <i class="fas fa-image-slash"></i>
                                    <span>Sin imagen cargada</span>
                                </div>
                            }
                            <p class="edit-img-hint mt-3">Usa una imagen clara para el catálogo y mantén la misma línea visual del resto de juegos.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de acción -->
            <div class="d-flex flex-wrap gap-3 mt-4 pt-3" style="border-top: 1px solid rgba(124,58,237,0.2);">
                <button type="submit" class="btn-arcade-primary">
                    <i class="fas fa-save me-2"></i>Guardar cambios
                </button>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-arcade-sm btn-arcade-danger">
                    <i class="fas fa-trash me-1"></i>Eliminar videojuego
                </a>
                <a asp-action="Index" class="btn-arcade-sm btn-arcade-outline">
                    <i class="fas fa-arrow-left me-1"></i>Volver al catálogo
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
