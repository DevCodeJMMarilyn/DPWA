<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MishiGames</title>
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet">
    <!-- Google Fonts: Orbitron + Rajdhani -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <!-- Estilos Arcade MishiGames -->
    <style>
        :root {
            --arcade-dark:   #0a0014;
            --arcade-violet: #7c3aed;
            --arcade-blue:   #2563eb;
            --neon-purple:   #c084fc;
            --neon-blue:     #60a5fa;
            --neon-pink:     #f472b6;
            --text-bright:   #f0e6ff;
            --text-muted:    #a78bca;
            --grad-main:     linear-gradient(135deg, #1e0533 0%, #0a0a2e 50%, #0a1628 100%);
            --grad-sidebar:  linear-gradient(180deg, #120025 0%, #0c0a2e 100%);
            --grad-navbar:   linear-gradient(90deg, #0d0026, #0a0a2e, #001135);
            --grad-accent:   linear-gradient(135deg, #7c3aed, #2563eb);
        }

        body {
            background: var(--grad-main);
            background-attachment: fixed;
            color: var(--text-bright);
            font-family: 'Rajdhani', 'Segoe UI', sans-serif;
            min-height: 100vh;
        }

        /* Arcade scanlines */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent, transparent 2px,
                rgba(0,0,0,0.04) 2px, rgba(0,0,0,0.04) 4px
            );
            pointer-events: none;
            /* Low z-index so dropdowns and interactive elements render on top */
            z-index: 1;
        }

        /* NAVBAR */
        .navbar {
            background: var(--grad-navbar) !important;
            border-bottom: 2px solid var(--arcade-violet);
            box-shadow: 0 4px 30px rgba(124,58,237,0.4);
            padding: 0.7rem 1.5rem;
        }

        .navbar-brand {
            font-family: 'Orbitron', monospace !important;
            font-size: 1.5rem !important;
            font-weight: 900;
            letter-spacing: 2px;
            background: linear-gradient(90deg, #c084fc, #60a5fa, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            filter: drop-shadow(0 0 8px rgba(192,132,252,0.7));
            transition: filter 0.3s;
        }

        .navbar-brand:hover {
            filter: drop-shadow(0 0 16px rgba(192,132,252,1));
            text-decoration: none;
        }

        /* SIDEBAR */
        .sidebar {
            min-height: 100vh;
            background: var(--grad-sidebar);
            border-right: 1px solid rgba(124,58,237,0.3);
            padding-top: 20px;
            box-shadow: 4px 0 20px rgba(0,0,0,0.4);
        }

        .sidebar a {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 18px;
            border-radius: 10px;
            margin: 4px 10px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            transition: background 0.25s, color 0.25s, box-shadow 0.25s;
        }

        .sidebar a i {
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
            color: var(--neon-purple);
        }

        .sidebar a:hover {
            background: rgba(124,58,237,0.2);
            color: var(--neon-purple);
            box-shadow: 0 0 15px rgba(124,58,237,0.25);
        }

        .sidebar-title {
            color: var(--text-muted);
            font-family: 'Orbitron', monospace;
            font-size: 0.6rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 8px 18px 4px;
            margin-top: 10px;
            opacity: 0.6;
        }

        /* CONTENIDO */
        .content {
            padding: 30px;
        }

        /* FOOTER */
        footer {
            background: linear-gradient(90deg, #0d0026, #0e1840);
            border-top: 2px solid var(--arcade-violet);
            padding: 15px;
            text-align: center;
            margin-top: 40px;
            color: var(--text-muted);
            font-family: 'Rajdhani', sans-serif;
            letter-spacing: 1px;
            box-shadow: 0 -4px 20px rgba(124,58,237,0.3);
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            🕹️ MishiGames
        </a>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- SIDEBAR -->
            <div class="col-md-2 sidebar">
                <div class="sidebar-title">Navegación</div>
                <a asp-controller="Home" asp-action="Index">
                    <i class="fas fa-home"></i> Inicio
                </a>
                <a asp-controller="Home" asp-action="Privacy">
                    <i class="fas fa-shield-alt"></i> Privacidad
                </a>
                <a asp-controller="VideoJuegos" asp-action="Index">
                    <i class="fas fa-gamepad"></i> Videojuegos
                </a>
                <a href="#">
                    <i class="fas fa-shopping-bag"></i> Compras
                </a>
            </div>

            <!-- CONTENIDO -->
            <div class="col-md-10 content">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        <p>🕹️ &copy; @DateTime.Now.Year - <strong>MishiGames</strong> | Proyecto ASP.NET Core MVC</p>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
