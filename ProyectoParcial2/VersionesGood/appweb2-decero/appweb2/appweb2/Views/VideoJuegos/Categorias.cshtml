@model IEnumerable<appweb2.Models.Categoria>

@{
    ViewData["Title"] = "Categorias";
    var esAdmin = string.Equals(Context.Session.GetString("rol"), "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Categorias</h2>
            <p class="text-muted mb-0">Explora el catalogo filtrando por tipo de juego.</p>
        </div>
        @if (esAdmin)
        {
            <a class="btn btn-warning" asp-action="GestionCategorias">Gestionar categorias</a>
        }
    </div>

    <div class="row g-3">
        @foreach (var categoria in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <a class="btn btn-outline-primary w-100" asp-controller="VideoJuegos" asp-action="PorCategoria" asp-route-id="@categoria.Id">
                    @categoria.Nombre
                </a>
            </div>
        }
    </div>
</div>
