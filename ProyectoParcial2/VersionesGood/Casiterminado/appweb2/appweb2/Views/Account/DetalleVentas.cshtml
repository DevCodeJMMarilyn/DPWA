@model IEnumerable<appweb2.Models.VentaViewModel>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Detalle Ventas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0">Detalle Ventas</h3>
            <a asp-controller="Account" asp-action="Dashboard" class="btn btn-secondary btn-sm">Volver</a>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-warning">
                @ViewBag.Error
            </div>
        }

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Desde</label>
                        <input type="date" name="desde" class="form-control" value="@(ViewBag.Desde != null ? ((DateTime)ViewBag.Desde).ToString("yyyy-MM-dd") : "")" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Hasta</label>
                        <input type="date" name="hasta" class="form-control" value="@(ViewBag.Hasta != null ? ((DateTime)ViewBag.Hasta).ToString("yyyy-MM-dd") : "")" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary">Filtrar</button>
                        <a asp-controller="Account" asp-action="DetalleVentas" class="btn btn-outline-secondary">Limpiar</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Compra</th>
                            <th>Usuario</th>
                            <th>VideoJuego</th>
                            <th>Cantidad</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Código</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.idCompra</td>
                                    <td>@item.UsuarioId</td>
                                    <td>@(!string.IsNullOrWhiteSpace(item.VideoJuegoTitulo) ? item.VideoJuegoTitulo : item.VideoJuegosId)</td>
                                    <td>@item.cantidad</td>
                                    <td>@item.total</td>
                                    <td>@item.estadoCompra</td>
                                    <td>@item.fechaHoraTransaccion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.codigoTransaccion</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No se encontraron ventas para el rango de fechas seleccionado.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2 flex-wrap">
            @for (int i = 1; i <= (int)ViewBag.TotalPaginas; i++)
            {
                if (i == (int)ViewBag.PaginaActual)
                {
                    <span class="btn btn-primary btn-sm disabled">@i</span>
                }
                else
                {
                    <a class="btn btn-outline-primary btn-sm"
                       asp-controller="Account"
                       asp-action="DetalleVentas"
                       asp-route-pagina="@i"
                       asp-route-desde="@(ViewBag.Desde != null ? ((DateTime)ViewBag.Desde).ToString("yyyy-MM-dd") : null)"
                       asp-route-hasta="@(ViewBag.Hasta != null ? ((DateTime)ViewBag.Hasta).ToString("yyyy-MM-dd") : null)">@i</a>
                }
            }
        </div>
    </div>

</body>
</html>
