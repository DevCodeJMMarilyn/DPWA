@model appweb2.Models.GestionCategoriasViewModel

@{
    ViewData["Title"] = "Gestion de categorias";
}

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Gestion de categorias</h2>
            <p class="text-muted mb-0">Como admin puedes crear, renombrar y eliminar categorias desde esta pantalla.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-action="Categorias">Ver categorias publicas</a>
            <a class="btn btn-outline-warning" asp-action="Create">Nuevo videojuego</a>
        </div>
    </div>

    @if (TempData["CategoriaMensaje"] is string mensaje && !string.IsNullOrWhiteSpace(mensaje))
    {
        <div class="alert alert-success">@mensaje</div>
    }

    @if (TempData["CategoriaError"] is string error && !string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h3 class="h5 mb-0">Agregar categoria</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CrearCategoria" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-3">
                            <label asp-for="NuevaCategoriaNombre" class="form-label">Nombre</label>
                            <input asp-for="NuevaCategoriaNombre" class="form-control" placeholder="Ej. RPG, Deportes, Terror" />
                            <span asp-validation-for="NuevaCategoriaNombre" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-warning w-100">Guardar categoria</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h3 class="h5 mb-0">Categorias actuales</h3>
                </div>
                <div class="card-body">
                    @if (Model.Categorias.Any())
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Categoria</th>
                                        <th>Videojuegos</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var categoria in Model.Categorias)
                                    {
                                        <tr>
                                            <td>
                                                <form asp-action="EditarCategoria" method="post" class="d-flex flex-wrap gap-2">
                                                    <input type="hidden" name="id" value="@categoria.Id" />
                                                    <input type="text" name="nombre" value="@categoria.Nombre" class="form-control" style="min-width: 220px;" />
                                                    <button type="submit" class="btn btn-outline-primary btn-sm">Renombrar</button>
                                                </form>
                                            </td>
                                            <td>
                                                <span class="badge text-bg-secondary">@categoria.VideoJuegos.Count</span>
                                            </td>
                                            <td class="text-end">
                                                <form asp-action="EliminarCategoria" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@categoria.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">Todavia no hay categorias registradas.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
