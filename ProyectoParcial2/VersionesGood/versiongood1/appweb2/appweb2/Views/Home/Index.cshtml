 @model IEnumerable<appweb2.Models.VideoJuego>
@{
    ViewData["Title"] = "Home Page";
    Layout = "admin";
}

<h2>Videojuegos Disponibles</h2>
<div class="row">
    @foreach (var juego in Model)
    {
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body">
                    <img src="@juego.Imagen" width="120" />
                    <h5 class="card-title">@juego.Titulo </h5>
                    <p class="card-text">@juego.Descripcion </p>
                    <p><strong>Categoria: </strong>@(juego.Categoria != null ? juego.Categoria.Nombre : "") </p>
                    <p><strong>Precio: </strong>$@juego.Precio </p>

                </div>
            </div>
        </div>

    }
</div>

@* <h1>@Model.promedio </h1> *@