@model IEnumerable<appWeb2.Models.VideoJuegos>

@{
    ViewData["Title"] = "Panel Admin";
}

<h2 class="text-warning text-center mb-4">
    Panel de Administración de Videojuegos
</h2>

<div class="text-center mb-4">
    <a asp-action="Create" class="btn btn-success">
        + Nuevo Juego
    </a>
</div>

<div class="container">
    <div class="row g-4">

        @foreach (var juego in Model)
        {
            <div class="col-md-4">

                <div class="card p-3 shadow text-center">

                    <h5 class="fw-bold">@juego.titulo</h5>

                    <img src="@juego.imagen"
                         class="img-fluid rounded mb-2"
                         style="height:150px; object-fit:cover;" />

                    <p><strong>Precio:</strong> $@juego.precio</p>
                    <p><strong>Categoría:</strong> @juego.idcategoria</p>
                    <p><strong>Edad:</strong> +@juego.edadMinima</p>

                    <div class="d-flex justify-content-center gap-2">

                        <a asp-action="Edit" asp-route-id="@juego.Id"
                           class="btn btn-warning btn-sm">
                            Editar
                        </a>

                        <a asp-action="Delete" asp-route-id="@juego.Id"
                           class="btn btn-danger btn-sm">
                            Eliminar
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
</div>