@model IEnumerable<appWeb2.Models.VideoJuegos>

@{
    ViewData["Title"] = "Administrar Videojuegos";
}

<div class="container mt-5">
    <div class="row text-center mb-5">

        @* <!-- CATEGORÍAS -->
        <div class="col-md-3 mb-3">
            <a asp-controller="VideoJuegos" asp-action="Categorias" style="text-decoration:none;">
                <div class="feature-card">
                    <i class="fas fa-gamepad"></i>
                    <h5>Categorías</h5>
                    <p>Explora por tipo de juego</p>
                </div>
            </a>
        </div> *@

        <!-- MÁS VENDIDOS (opcional, si no tienes acción) -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-fire"></i>
                <h5>Más Vendidos</h5>
                <p>Los juegos más populares</p>
            </div>
        </div>

        <!-- NUEVOS -->
        <div class="col-md-3 mb-3">
            <a asp-controller="VideoJuegos" asp-action="Nuevos" style="text-decoration:none;">
                <div class="feature-card">
                    <i class="fas fa-star"></i>
                    <h5>Nuevos Juegos</h5>
                    <p>Lo último en la tienda</p>
                </div>
            </a>
        </div>

        <!-- PROMOCIONES -->
        <div class="col-md-3 mb-3">
            <a asp-controller="VideoJuegos" asp-action="Promociones" style="text-decoration:none;">
                <div class="feature-card">
                    <i class="fas fa-tags"></i>
                    <h5>Promociones</h5>
                    <p>Ofertas especiales</p>
                </div>
            </a>
        </div>

    </div>

    <h2 class="text-center fw-bold mb-4" style="color: #ffc950;">Videojuegos Disponibles</h2>
    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- BADGE DE EDAD -->
                    <div class="badge-top">+@juego.edadMinima</div>

                    <!-- CORAZÓN DE FAVORITO -->
                    <a href="#" class="favorite">
                        <i class="fa-solid fa-heart"></i>
                    </a>

                    <!-- IMAGEN -->
                    <img src="@juego.imagen" class="card-img-top game-img" alt="@juego.titulo" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juego.titulo
                        </h5>

                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juego.precio
                        </h4>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2" style="color: #ffc950;"></i>
                            <span class="text-muted">@juego.idcategoria</span>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

</div>
