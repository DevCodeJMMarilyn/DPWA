@model appWeb2.Models.VideoJuegos

@{
    ViewData["Title"] = "Eliminar Videojuego";
}

<div class="container mt-4" style="max-width:500px;">
    <h2 class="fw-bold text-danger mb-4">🗑️ Eliminar Videojuego</h2>

    <div class="card shadow p-4">
        <h5 class="mb-3">¿Estás seguro que deseas eliminar este juego?</h5>

        <ul class="list-group mb-4">
            <li class="list-group-item"><strong>Título:</strong> @Model.titulo</li>
            <li class="list-group-item"><strong>Categoría:</strong> @Model.idcategoria</li>
            <li class="list-group-item"><strong>Precio:</strong> $@Model.precio</li>
        </ul>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger fw-bold">Sí, eliminar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
